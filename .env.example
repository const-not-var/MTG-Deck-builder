# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is already in .gitignore.

# MongoDB Atlas connection string
# Get it from: Atlas dashboard → your cluster → Connect → Drivers → copy URI
# Replace <username>, <password>, and <dbname> with your Atlas values
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# NextAuth secret — any long random string (run: openssl rand -base64 32)
AUTH_SECRET=replace-with-a-long-random-string

# The public URL of your deployed app (no trailing slash)
# For Vercel this is set automatically; you can leave it blank locally
NEXTAUTH_URL=https://your-app.vercel.app

# Resend API key — for password reset emails
# Sign up free at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address to send from (must be verified in your Resend dashboard)
# Leave blank to use the Resend test address (only works for your own account email)
RESEND_FROM_EMAIL=Commander Vault <noreply@yourdomain.com>
